# Puerto del servidor (por defecto 3001)
PORT=3001

# URL base de la API (para documentación y CORS)
# API_BASE_URL=https://file-manager.tudominio.com

# Cloudflare R2 (o S3 compatible)
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tu-bucket
# URL pública para acceder a los archivos (dominio custom o R2 dev)
R2_PUBLIC_URL=https://tu-dominio.com
# Alternativa: R2_PUBLIC_DOMAIN si usas el dominio por defecto de R2
