# Puerto del servidor (Railway inyecta PORT en producción)
PORT=3001

# URL base de la API (para documentación y CORS)
# API_BASE_URL=https://tu-app.railway.app

# ─── Cloudflare R2 (S3 compatible) ─────────────────────────────────────────
R2_ACCOUNT_ID=<tu_account_id>
R2_BUCKET=cafip-storage
R2_ACCESS_KEY_ID=<tu_access_key>
R2_SECRET_ACCESS_KEY=<tu_secret_key>
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# URL pública para acceder a los archivos
R2_PUBLIC_DOMAIN=https://storage.caf-ip.com
# Alternativa: R2_PUBLIC_URL si usas otra URL

# ─── Base de datos ─────────────────────────────────────────────────────────
# Ejemplos: PostgreSQL, MySQL, MongoDB
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=mysql://user:password@host:3306/dbname
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname
DATABASE_URL=
